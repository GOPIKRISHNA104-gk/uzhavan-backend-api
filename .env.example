# Uzhavan AI Backend Environment Variables

# App Settings
DEBUG=true

# JWT Secret (change this in production!)
SECRET_KEY=your-super-secret-key-change-in-production-use-a-long-random-string

# Google Gemini API Key (required for AI features)
GEMINI_API_KEY=

# OpenWeatherMap API Key (optional, for weather features)
WEATHER_API_KEY=

# Database (default: SQLite)
DATABASE_URL=sqlite+aiosqlite:///./uzhavan.db
